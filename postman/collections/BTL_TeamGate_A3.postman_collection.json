            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"card_id\": \"CARD-2026-001\",\n  \"gate_id\": \"GATE-01\",\n  \"direction\": \"in\",\n  \"timestamp\": \"2026-05-19T08:30:00Z\"\n}"
