                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('type');",
                  "  });",
                  "} else {",
                  "  pm.test('Mock may not validate token — accepted', function () {",
                  "    pm.expect([201, 401, 403]).to.include(pm.response.code);",
                  "  });",
