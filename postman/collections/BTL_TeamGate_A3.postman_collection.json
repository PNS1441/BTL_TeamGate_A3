  "item": [
    {
      "name": "01_Functional",
      "item": [
        {
          "name": "TC01 — Health check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has status=ok', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('ok');",
                  "  pm.expect(json.service).to.eql('access-gate');",
                  "});",
                  "",
                  "pm.test('Response has version field', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('version');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "TC02 — Create access event (happy path — accepted)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"card_id\": \"CARD-2026-001\",\n  \"gate_id\": \"GATE-01\",\n  \"direction\": \"in\",\n  \"timestamp\": \"2026-05-19T08:30:00Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/access-events",
              "host": ["{{baseUrl}}"],
              "path": ["access-events"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has event_id', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('event_id');",
                  "  pm.collectionVariables.set('lastEventId', json.event_id);",
                  "});",
                  "",
                  "pm.test('Result is accepted for active card', function () {",
                  "  if (pm.environment.get('env') === 'local') {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.result).to.eql('accepted');",
                  "  } else {",
                  "    pm.expect([201]).to.include(pm.response.code);",
                  "  }",
                  "});",
                  "",
                  "pm.test('Direction is correct', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.direction).to.be.oneOf(['in', 'out']);",
                  "});"
                ]
              }
            }
          ]
        },
